{
  "name": "fresh-compare-mini-app",
  "version": "1.0.0",
  "private": true,
  "description": "水果肉类商品对比小程序",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "build:tt": "taro build --type tt",
    "build:alipay": "taro build --type alipay",
    "build:h5": "taro build --type h5",
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:tt": "npm run build:tt -- --watch",
    "dev:alipay": "npm run build:alipay -- --watch",
    "dev:h5": "npm run build:h5 -- --watch"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "author": "",
  "dependencies": {
    "@babel/runtime": "^7.7.7",
    "@tarojs/components": "4.1.9",
    "@tarojs/helper": "4.1.9",
    "@tarojs/plugin-framework-vue3": "4.1.9",
    "@tarojs/plugin-html": "4.1.9",
    "@tarojs/plugin-platform-alipay": "4.1.9",
    "@tarojs/plugin-platform-h5": "4.1.9",
    "@tarojs/plugin-platform-tt": "4.1.9",
    "@tarojs/plugin-platform-weapp": "4.1.9",
    "@tarojs/runtime": "4.1.9",
    "@tarojs/shared": "4.1.9",
    "@tarojs/taro": "4.1.9",
    "vue": "^3.3.4",
    "pinia": "^2.1.7",
    "classnames": "^2.5.1",
    "sass": "^1.62.1"
  },
  "devDependencies": {
    "@babel/core": "^7.8.0",
    "@tarojs/cli": "4.1.9",
    "@tarojs/webpack5-runner": "4.1.9",
    "@types/webpack-env": "^1.13.6",
    "@vue/babel-plugin-jsx": "^1.1.1",
    "babel-preset-taro": "4.1.9",
    "typescript": "^5.1.0",
    "webpack": "5.78.0"
  }
}
